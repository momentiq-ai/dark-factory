{
  "name": "@momentiq/dark-factory-cli",
  "version": "2.0.0",
  "description": "Dark Factory OSS CLI — multi-vendor adversarial critic orchestration (Cursor, Codex, Gemini, Grok) with min-complete-quorum aggregation and trusted-surface rebind",
  "license": "Apache-2.0",
  "homepage": "https://momentiq.ai/dark-factory",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/momentiq-ai/dark-factory.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/momentiq-ai/dark-factory/issues"
  },
  "author": "Momentiq AI",
  "keywords": [
    "ai-agents",
    "code-review",
    "github-actions",
    "pr-automation",
    "multi-vendor",
    "agentic-sdlc",
    "claude-code",
    "cursor-sdk",
    "dark-factory",
    "critic",
    "quorum"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js"
    },
    "./trusted-surface": {
      "types": "./dist/trusted-surface/index.d.ts",
      "import": "./dist/trusted-surface/index.js"
    },
    "./compact": {
      "types": "./dist/compact/index.d.ts",
      "import": "./dist/compact/index.js"
    },
    "./evidence": {
      "types": "./dist/evidence/index.d.ts",
      "import": "./dist/evidence/index.js"
    },
    "./cycle-doc-validator": {
      "types": "./dist/cycle-doc-validator/index.d.ts",
      "import": "./dist/cycle-doc-validator/index.js"
    },
    "./branch-protection": {
      "types": "./dist/branch-protection/index.d.ts",
      "import": "./dist/branch-protection/index.js"
    },
    "./cycle-tracker-sync": {
      "types": "./dist/cycle-tracker-sync/index.d.ts",
      "import": "./dist/cycle-tracker-sync/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "import": "./dist/skills/index.js"
    }
  },
  "bin": {
    "df": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:python": "python3 -m pytest tests/cycle-doc-validator tests/branch-protection tests/cycle-tracker-sync -q",
    "test:all": "npm run test && npm run test:python",
    "test:watch": "vitest",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.12",
    "@google/genai": "^2.2.0",
    "@iarna/toml": "2.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@momentiq/dark-factory-schemas": "0.6.0",
    "@openai/codex-sdk": "^0.130.0",
    "@yarnpkg/lockfile": "1.1.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "openai": "^6.37.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/yarnpkg__lockfile": "^1.1.9",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
