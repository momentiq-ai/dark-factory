      "description": "Read-only catch-up on a handoff issue: derives live state + each linked work item's status + prints the rehydration note. No ownership change. No-arg resolves via 2-tier (open+@me first, then closed+@me within 7d). Works on open AND closed issues (closed = forensic catch-up).",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "issue": {
            "description": "Optional issue number. Omit to resolve via 2-tier lookup.",
