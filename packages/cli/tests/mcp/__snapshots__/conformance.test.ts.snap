        ],
        "type": "object",
      },
      "title": "List bundled Dark Factory skills",
    },
    {
      "annotations": {
        "openWorldHint": false,
        "readOnlyHint": true,
      },
      "description": "Summarize the .git/agent-reviews/_runs.ndjson audit trail. Optional ISO8601 \`since\` / \`until\` to constrain the window. Returns the narrowed spec view: { runs, bypasses, by_critic, by_verdict }. Read-only.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "since": {
            "description": "ISO8601 timestamp — drop events with ts < since (lexicographic comparison; works correctly for UTC ISO timestamps).",
            "type": "string",
          },
          "until": {
            "description": "ISO8601 timestamp — drop events with ts > until.",
            "type": "string",
          },
        },
        "type": "object",
      },
      "name": "df_stats",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "by_critic": {
            "additionalProperties": {
              "additionalProperties": false,
              "properties": {
                "approved": {
                  "type": "number",
                },
                "changes_requested": {
                  "type": "number",
                },
                "errors": {
                  "type": "number",
                },
                "finishes": {
                  "type": "number",
                },
                "starts": {
                  "type": "number",
                },
                "total_blockers": {
                  "type": "number",
                },
                "total_findings": {
                  "type": "number",
                },
                "total_high": {
                  "type": "number",
                },
              },
              "required": [
                "starts",
                "finishes",
                "errors",
                "approved",
                "changes_requested",
                "total_findings",
                "total_blockers",
                "total_high",
              ],
              "type": "object",
            },
            "description": "Per-critic-id stats over the window.",
            "type": "object",
          },
          "by_verdict": {
            "additionalProperties": false,
            "description": "Aggregate verdict counts.",
            "properties": {
              "approved": {
                "type": "number",
              },
              "changes_requested": {
                "type": "number",
              },
            },
            "required": [
              "approved",
              "changes_requested",
            ],
            "type": "object",
          },
          "bypasses": {
            "description": "Count of gate_bypassed events.",
            "type": "number",
          },
          "runs": {
            "description": "Count of review_started or review_finished events.",
            "type": "number",
          },
          "window": {
            "additionalProperties": false,
            "description": "Window metadata so callers can sanity-check the filter.",
            "properties": {
              "events_in_window": {
                "type": "number",
              },
              "events_total": {
                "type": "number",
              },
              "since": {
                "type": "string",
              },
              "until": {
                "type": "string",
              },
            },
            "required": [
              "events_in_window",
              "events_total",
            ],
            "type": "object",
          },
        },
        "required": [
          "runs",
          "bypasses",
          "by_critic",
          "by_verdict",
          "window",
        ],
        "type": "object",
      },
      "title": "Audit-trail stats",
    },
  ],
}
`;
