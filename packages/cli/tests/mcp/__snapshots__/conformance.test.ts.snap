      "description": "List every skill bundled with @momentiq/dark-factory-cli: name, manifest version, summary, originating repo (when known). The complementary action is df_skills_install.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "properties": {},
        "type": "object",
      },
      "name": "df_skills_list",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "skills": {
            "description": "Sorted alphabetically by name. Empty when no skills are bundled.",
            "items": {
              "additionalProperties": false,
              "properties": {
                "name": {
                  "type": "string",
                },
                "originatingRepo": {
                  "type": "string",
