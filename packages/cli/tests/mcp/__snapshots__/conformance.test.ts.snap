      "title": "Diagnose a critic failure",
    },
    {
      "arguments": [
        {
          "description": "Comma- or newline-separated list of alternatives considered. Each is added as a bullet under the Alternatives section.",
          "name": "alternatives",
          "required": true,
        },
        {
          "description": "One-paragraph context — why is this decision needed now?",
          "name": "context",
          "required": true,
        },
        {
          "description": "One-sentence statement of the decision being made.",
          "name": "decision",
          "required": true,
        },
      ],
      "description": "Return a templated Architecture Decision Record skeleton with bullet metadata + standard sections.",
      "name": "df.draft_adr",
      "title": "Draft an ADR",
    },
    {
      "arguments": [
        {
          "description": "The work-stream's operator-facing title — what shows up in \`df handoffs\` rows and as the dedicated handoff Issue's title. Embedded in the note body (it is NOT interpolated into any copy-pastable command).",
          "name": "title",
          "required": true,
        },
      ],
      "description": "Return the judgment template for composing a rehydration note to hand off a work-stream onto the v2 Issue-anchored stack. Carries the note format, the security rule (setup steps yes, secrets never), and what to write vs. omit. The agent composes the note, then calls the df_handoff tool with it (the note lands on the dedicated handoff Issue's body). Pure template — no side effects.",
      "name": "df.handoff",
      "title": "Compose an agent handoff note",
    },
    {
      "arguments": [
        {
          "description": "Local filesystem path to the candidate consumer repo. The prompt instructs the agent to scan + describe the repo's current state; the actual scanning is done by the agent's tools, not by this prompt.",
          "name": "repo_path",
          "required": true,
        },
      ],
      "description": "Return the analysis prompt template that the cycle2 \`df onboard\` agent uses when scanning a candidate consumer repo. Pure template — no side effects.",
      "name": "df.onboarding_analysis",
      "title": "Onboarding analysis prompt",
    },
    {
      "arguments": [
        {
          "description": "The handoff Issue number being rehydrated (or accepted). Used only to address the prompt; the tool derives live state with fixed, script-owned \`gh issue view\` + per-link \`gh pr view\` / \`gh issue view\` commands.",
          "name": "issue",
          "required": true,
        },
      ],
      "description": "Return the judgment template for resuming work from a v2 Issue-anchored handoff: the live-state-first ritual and the hard rule that nothing transcribed from the note is ever executed. Use alongside the df_rehydrate (read-only) or df_accept (claim + rehydrate + close) tools, which derive live state themselves from the Issue and its linked work items. Pure template — no side effects.",
      "name": "df.rehydrate",
      "title": "Rehydrate from an agent handoff note",
    },
    {
      "arguments": [
        {
          "description": "How many most-recent events to embed (string for prompt API compat; parsed as int; clamped 1..500; default 25).",
          "name": "limit",
          "required": true,
        },
      ],
      "description": "Embed a snapshot of recent telemetry events into a structured prompt + ask the client's LLM to produce an operator-friendly summary. The server reads telemetry from disk; no LLM call.",
      "name": "df.summarize_recent_runs",
      "title": "Summarize recent critic runs",
    },
    {
      "arguments": [
        {
          "description": "Cycle id (e.g. 'cycle6' or 'cycle331.7'). Maps to the filename \`docs/roadmap/cycles/<id>-slug.md\`.",
          "name": "cycle_id",
          "required": true,
        },
        {
          "description": "One-paragraph scope statement — what's in vs out for this cycle.",
          "name": "scope",
          "required": true,
        },
        {
          "description": "Short title for the cycle (after the em-dash).",
          "name": "title",
          "required": true,
        },
      ],
      "description": "Return a templated cycle-doc skeleton with frontmatter + standard sections. The client's LLM populates the body.",
      "name": "df.write_cycle_doc",
      "title": "Write a cycle doc",
    },
  ],
  "resourceTemplates": [
    {
      "description": "Structured ADR — { id, frontmatter, body, status, supersedes? }. Same data as df_adr_read.",
