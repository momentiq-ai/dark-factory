            "description": "Set when status='errored'.",
            "type": "string",
          },
          "findings": {
            "additionalProperties": false,
            "description": "Narrowed findings (same shape as df_findings) — set when status='completed'.",
            "properties": {
              "commit": {
                "type": "string",
              },
              "critics": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "findings": {
                      "items": {
                        "additionalProperties": false,
                        "properties": {
                          "file": {
                            "type": "string",
                          },
                          "line": {
                            "type": "number",
                          },
                          "message": {
                            "type": "string",
                          },
                          "rule": {
                            "type": "string",
                          },
                          "severity": {
                            "type": "string",
                          },
                        },
                        "required": [
                          "severity",
                          "rule",
                          "message",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "id": {
                      "type": "string",
                    },
                    "status": {
                      "type": "string",
                    },
                    "verdict": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "id",
                    "status",
                    "findings",
                  ],
                  "type": "object",
                },
                "type": "array",
              },
            },
            "required": [
              "commit",
              "critics",
            ],
            "type": "object",
          },
          "status": {
            "description": "Lifecycle phase.",
            "enum": [
              "running",
              "completed",
              "errored",
            ],
            "type": "string",
          },
          "verdict": {
            "description": "Set when status='completed'.",
            "enum": [
              "APPROVED",
              "CHANGES_REQUESTED",
            ],
            "type": "string",
          },
        },
        "required": [
          "status",
        ],
        "type": "object",
      },
      "title": "Poll a running review",
    },
