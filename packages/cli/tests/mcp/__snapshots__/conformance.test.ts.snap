      "name": "df_doctor",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "checks": {
            "description": "Ordered list of individual check results — same order as runDoctor emits them.",
            "items": {
              "additionalProperties": false,
              "properties": {
                "message": {
                  "description": "Human-readable detail; for non-pass entries the remediation hint is appended after ' — fix: '.",
                  "type": "string",
                },
                "name": {
                  "description": "Stable id for the check (e.g. 'node_version').",
                  "type": "string",
                },
                "status": {
                  "description": "'pass' — check OK. 'fail' — check failed and gates ok=false. 'warn' — check failed but is optional (shadow-mode); does not gate ok.",
                  "enum": [
                    "pass",
                    "fail",
                    "warn",
                  ],
                  "type": "string",
                },
              },
              "required": [
                "name",
                "status",
              ],
              "type": "object",
            },
            "type": "array",
          },
          "ok": {
            "description": "True if every non-optional check passed. Optional (shadow-mode) check failures emit status='warn' but do not gate ok.",
            "type": "boolean",
          },
        },
        "required": [
          "ok",
          "checks",
        ],
        "type": "object",
      },
      "title": "Dark Factory doctor",
    },
    {
      "annotations": {
        "openWorldHint": false,
        "readOnlyHint": true,
      },
      "description": "Read the per-critic findings recorded for a commit by \`df review\`. Returns the narrowed view: severity, file, line, rule, message. For full artifact context (verdict reasoning, quality-gate evidence, retry counts) call df_show_run.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "commit": {
            "description": "Commit reference — anything \`git rev-parse\` accepts (SHA, 'HEAD', branch name, ref). Resolved server-side.",
            "minLength": 1,
            "type": "string",
          },
        },
        "required": [
          "commit",
        ],
        "type": "object",
      },
      "name": "df_findings",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "commit": {
            "description": "Resolved commit SHA the artifact records.",
            "type": "string",
          },
          "critics": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "findings": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "file": {
                        "description": "File path the critic cites, when present.",
                        "type": "string",
                      },
                      "line": {
                        "description": "Line number the critic cites, when present.",
                        "type": "number",
                      },
                      "message": {
                        "description": "Concrete evidence text from the critic. For full impact + remediation context call df_show_run on the same commit.",
                        "type": "string",
                      },
                      "rule": {
                        "description": "Rule-like classifier — maps to the source ReviewFinding.category. Critic-supplied; format depends on the critic.",
                        "type": "string",
                      },
                      "severity": {
                        "description": "Severity tag from the source ReviewFinding ('blocker' | 'high' | 'medium' | 'low' | 'note').",
                        "type": "string",
                      },
                    },
                    "required": [
                      "severity",
                      "rule",
                      "message",
                    ],
                    "type": "object",
                  },
                  "type": "array",
                },
                "id": {
                  "description": "Critic id (e.g. 'cursor-local-chief-engineer').",
                  "type": "string",
                },
                "status": {
                  "description": "'pending' | 'running' | 'complete' | 'error'.",
                  "type": "string",
                },
                "verdict": {
                  "description": "'APPROVED' | 'CHANGES_REQUESTED', when set.",
                  "type": "string",
                },
              },
              "required": [
                "id",
                "status",
                "findings",
              ],
              "type": "object",
            },
            "type": "array",
          },
        },
        "required": [
          "commit",
          "critics",
        ],
        "type": "object",
      },
      "title": "Read review findings for a commit",
    },
    {
      "annotations": {
        "openWorldHint": false,
        "readOnlyHint": true,
      },
      "description": "Evaluate \`df gate-push\`'s gate over a git pre-push protocol range. Default (Cycle 13 / dark-factory-platform#149): evaluates ONLY the HEAD (final) commit of each push update; intermediate commits are iteration receipts (inspect with the matching \`df findings --range\` CLI subcommand or the \`df://repo/findings/{sha}\` resource) and do not influence the verdict. Set \`full_range: true\` to opt into the legacy per-commit semantic (gates every commit; any blocker vetoes). Soundness caveat: each per-SHA artifact reviews \`parent..commit\` only, NOT \`base..tip\` — HEAD's APPROVED verdict proves only the last incremental change. Use \`full_range: true\` (or the CI cold-path) when cumulative soundness matters. The \`stdin_protocol\` input is what git would write to the husky pre-push hook's stdin — newline-separated \`<localRef> <localSha> <remoteRef> <remoteSha>\` lines. Returns the aggregate verdict + per-commit blocking reasons. Read-only (does not push, does not write artifacts).",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "full_range": {
            "description": "When true, restores the pre-Cycle-13 per-commit semantic: every commit in the push range is gated and any blocker vetoes the push. Default false (HEAD-only). Mirrors the \`df gate-push --full-range\` CLI flag and the DF_GATE_FULL_RANGE=1 env. Use for forensic replay or per-commit deploy-log audit.",
            "type": "boolean",
          },
          "profile": {
            "description": "Profile name (overrides AGENT_REVIEW_PROFILE env). Defaults to \`local\`.",
            "type": "string",
          },
          "stdin_protocol": {
            "description": "Git pre-push protocol content (the same text git writes to a husky pre-push hook's stdin). Format: one line per ref update, \`<localRef> <localSha> <remoteRef> <remoteSha>\`, separated by newlines.",
            "type": "string",
          },
        },
        "required": [
          "stdin_protocol",
        ],
        "type": "object",
      },
      "name": "df_gate_push",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "bypass_allowed": {
            "description": "Mirror of loaded config policy.allowEmergencyBypass — set regardless of verdict for client UX.",
            "type": "boolean",
          },
          "commits_evaluated": {
            "description": "How many commits the input range contained.",
            "type": "number",
          },
          "reasons": {
            "description": "Per-commit blocking reasons (empty when verdict=allow).",
            "items": {
              "additionalProperties": false,
              "properties": {
                "commit": {
                  "type": "string",
                },
                "criticId": {
                  "type": "string",
                },
                "detail": {
                  "type": "string",
                },
                "reason": {
                  "type": "string",
                },
              },
              "required": [
                "commit",
                "reason",
              ],
              "type": "object",
            },
            "type": "array",
          },
          "verdict": {
            "description": "'allow' — all commits pass. 'block' — at least one commit blocked AND policy.allowEmergencyBypass is false (no override path). 'bypass-required' — at least one commit blocked but policy permits emergency bypass; an agent client can prompt the user for a reason and call df_bypass.",
            "enum": [
              "block",
              "allow",
              "bypass-required",
            ],
            "type": "string",
          },
        },
        "required": [
          "verdict",
          "reasons",
          "commits_evaluated",
          "bypass_allowed",
        ],
        "type": "object",
      },
      "title": "Evaluate the pre-push gate for a pushed range",
    },
    {
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true,
        "readOnlyHint": false,
      },
      "description": "Put a work-stream on the handoff stack: upsert the marker-bounded rehydration \`note\` you compose as the dedicated handoff issue's body, add the \`handoff\` label, and leave the issue unassigned (open on the stack). Auto-creates a new issue if none is supplied or none is owned by @me. Scrubs the note for secret-shaped content first and REFUSES on a match (setup steps yes, secrets never).",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "issue": {
            "description": "Explicit handoff issue number (positive integer). Omit to update @me's open handoff or create a new one.",
            "type": "string",
          },
          "link": {
            "description": "Work items to link (PR/issue ref: number, owner/repo#N, or URL).",
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "new": {
            "description": "Force-create a new issue even if @me already has an open handoff.",
            "type": "boolean",
          },
          "note": {
            "description": "The composed rehydration note body, bounded by the v1 markers (<!-- agent-context:v1 --> … <!-- /agent-context:v1 -->).",
            "minLength": 1,
            "type": "string",
          },
          "unlink": {
            "description": "Work items to unlink (same ref forms as \`link\`).",
            "items": {
              "type": "string",
            },
            "type": "array",
          },
        },
        "required": [
          "note",
        ],
        "type": "object",
      },
      "name": "df_handoff",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "created": {
            "description": "True iff this call created the issue.",
            "type": "boolean",
          },
          "issue": {
            "description": "The issue the note landed on.",
            "type": "string",
          },
          "note_url": {
            "description": "html_url of the upserted handoff issue.",
            "type": "string",
          },
        },
        "required": [
          "issue",
          "note_url",
          "created",
        ],
        "type": "object",
      },
      "title": "Hand off a work-stream",
    },
