    {
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false,
        "readOnlyHint": false,
      },
      "description": "Render + install one (or all) bundled skill(s) into the consumer repo's .claude/skills/<name>/ directory. The skill body templates are rendered against the consumer's darkfactory.yaml (with sensible defaults when keys are absent). The rendered files carry a GENERATED header — a re-install with the same inputs is a no-op; a re-install with different inputs overwrites; a re-install where the rendered file has been hand-edited is SKIPPED unless force=true. Bundled skills: chief-engineer-review, chief-engineer-blitz.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "all": {
            "description": "If true, install every skill declared \`enabled: true\` in darkfactory.yaml#skills. Mutually exclusive with skillName.",
            "type": "boolean",
          },
          "force": {
            "description": "Overwrite hand-edited rendered files. Off by default — re-install of a hand-edited file returns action=skipped instead.",
            "type": "boolean",
          },
          "skillName": {
            "description": "Skill name to install. Required unless 'all' is true. One of: chief-engineer-review, chief-engineer-blitz.",
            "minLength": 1,
            "type": "string",
          },
          "targetDir": {
            "description": "Override the install location (default: <cwd>/.claude/skills/<name>/). Tests pass a fixture dir; production callers omit this.",
            "type": "string",
          },
        },
        "type": "object",
      },
      "name": "df_skills_install",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "installed": {
            "description": "One result per installed skill. action='skipped' means the file exists without the GENERATED marker and force was not set.",
            "items": {
              "additionalProperties": false,
              "properties": {
                "configIsDefault": {
                  "type": "boolean",
                },
                "configPath": {
                  "type": "string",
                },
                "files": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "absoluteTarget": {
                        "type": "string",
                      },
                      "action": {
                        "enum": [
                          "created",
                          "updated",
                          "unchanged",
                          "skipped",
                        ],
                        "type": "string",
                      },
                      "reason": {
                        "type": "string",
                      },
                      "relTarget": {
                        "type": "string",
                      },
                    },
                    "required": [
                      "relTarget",
                      "absoluteTarget",
                      "action",
                    ],
                    "type": "object",
                  },
                  "type": "array",
                },
                "manifestVersion": {
                  "type": "string",
                },
                "resolvedVariables": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "name": {
                        "type": "string",
                      },
                      "value": {
                        "type": "string",
                      },
                    },
                    "required": [
                      "name",
                      "value",
                    ],
                    "type": "object",
                  },
                  "type": "array",
                },
                "skillName": {
                  "type": "string",
                },
