          "note": {
            "type": [
              "string",
              "null",
            ],
          },
          "state": {
            "type": "string",
          },
          "title": {
            "type": "string",
          },
        },
        "required": [
          "issue",
          "state",
          "title",
          "linked_items",
          "note",
        ],
        "type": "object",
      },
      "title": "Rehydrate a handoff issue (read-only)",
    },
    {
      "annotations": {
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": false,
        "readOnlyHint": false,
      },
      "description": "Kick off the multi-vendor adversarial critic against a commit. Returns a \`job_id\` immediately; the review runs in the background. Poll \`df_review_status\` with the same job_id to retrieve the verdict + findings once complete. Honors \`AGENT_REVIEW_PROFILE\` for subscription-auth pinning.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "commit": {
            "description": "Git ref to review — anything \`git rev-parse\` accepts.",
            "minLength": 1,
            "type": "string",
          },
          "profile": {
            "description": "Profile name (default: env AGENT_REVIEW_PROFILE or 'local'). Pins per-critic \`auth\` so subscription-auth flows are honored — see profile docs in @momentiq/dark-factory-cli.",
            "type": "string",
          },
        },
        "required": [
          "commit",
        ],
        "type": "object",
      },
      "name": "df_review",
      "outputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "expected_completion_seconds": {
            "description": "Approximate seconds until completion based on the cycle's default profile budget. Real time may exceed this.",
            "type": "number",
          },
          "job_id": {
            "description": "Opaque identifier — pass back to df_review_status.",
            "type": "string",
          },
          "started_at": {
            "description": "ISO8601 timestamp of when the job started running.",
            "type": "string",
          },
        },
        "required": [
          "job_id",
          "started_at",
          "expected_completion_seconds",
        ],
        "type": "object",
      },
      "title": "Run a critic review (async)",
    },
    {
      "annotations": {
        "openWorldHint": false,
        "readOnlyHint": true,
      },
      "description": "Look up the status of a review started via df_review. Returns 'running' while the review is in flight, 'completed' with verdict + findings once done, or 'errored' with the failure reason.",
      "inputSchema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "job_id": {
            "description": "Job id returned by df_review.",
