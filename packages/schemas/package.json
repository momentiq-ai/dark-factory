{
  "name": "@momentiq/dark-factory-schemas",
  "version": "0.11.0",
  "description": "Dark Factory schemas — TypeScript types and JSON Schemas for darkfactory.yaml, evidence, and cycle-doc trailers",
  "license": "Apache-2.0",
  "homepage": "https://momentiq.ai/dark-factory",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/momentiq-ai/dark-factory.git",
    "directory": "packages/schemas"
  },
  "bugs": {
    "url": "https://github.com/momentiq-ai/dark-factory/issues"
  },
  "author": "Momentiq AI",
  "keywords": [
    "ai-agents",
    "code-review",
    "github-actions",
    "pr-automation",
    "multi-vendor",
    "agentic-sdlc",
    "claude-code",
    "cursor-sdk",
    "dark-factory",
    "critic",
    "quorum"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
